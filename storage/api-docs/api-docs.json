        "/api/v1/register": {
            "post": {
                "tags": [
                    "Autentikasi"
                ],
                "summary": "Daftar pengguna baru",
                "operationId": "6796c44e1f6079c411abbfed066c5907",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "description": "Nama lengkap pengguna",
                                        "type": "string",
                                        "example": "Budi Santoso"
                                    },
                                    "email": {
                                        "description": "Alamat email unik",
                                        "type": "string",
                                        "format": "email",
                                        "example": "budi@example.com"
                                    },
                                    "password": {
                                        "description": "Kata sandi minimal 8 karakter",
                                        "type": "string",
                                        "format": "password",
                                        "example": "rahasia123"
                                    },
                                    "password_confirmation": {
                                        "description": "Konfirmasi kata sandi",
                                        "type": "string",
                                        "format": "password",
                                        "example": "rahasia123"
                                    },
                                    "role": {
                                        "description": "Peran pengguna",
                                        "type": "string",
                                        "enum": [
                                            "student",
                                            "admin"
                                        ],
                                        "example": "student"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Pengguna berhasil didaftarkan",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Pengguna berhasil didaftarkan"
                                        },
                                        "access_token": {
                                            "type": "string"
                                        },
                                        "token_type": {
                                            "type": "string",
                                            "example": "Bearer"
                                        },
                                        "user": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Kesalahan validasi data"
                    }
                }
            }
        },
        "/api/v1/login": {
            "post": {
                "tags": [
                    "Autentikasi"
                ],
                "summary": "Masuk ke sistem",
                "operationId": "da2ca4d7a5cdec77b8b45a20373535cb",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "budi@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "rahasia123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Login berhasil"
                                        },
                                        "access_token": {
                                            "type": "string"
                                        },
                                        "token_type": {
                                            "type": "string",
                                            "example": "Bearer"
                                        },
                                        "user": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Kredensial tidak valid (Email belum terdaftar atau kata sandi salah)"
                    },
                    "422": {
                        "description": "Kesalahan validasi data atau akun tidak ditemukan"
                    }
                }
            }
        },
        "/api/v1/logout": {
            "post": {
                "tags": [
