                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Tautan atur ulang berhasil dikirim"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Kesalahan validasi data"
                    }
                }
            }
        },
        "/api/v1/reset-password": {
            "post": {
                "tags": [
                    "Atur Ulang Kata Sandi"
                ],
                "summary": "Atur ulang kata sandi pengguna",
                "operationId": "e1fec04a24297c4e70c35533b5621842",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "token",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "token": {
                                        "description": "Token dari email",
                                        "type": "string",
                                        "example": "TOKEN_DISINI"
                                    },
                                    "email": {
                                        "description": "Alamat email",
                                        "type": "string",
                                        "format": "email",
                                        "example": "budi@example.com"
                                    },
                                    "password": {
                                        "description": "Kata sandi baru",
                                        "type": "string",
                                        "format": "password",
                                        "example": "rahasia_baru123"
                                    },
                                    "password_confirmation": {
                                        "description": "Konfirmasi kata sandi baru",
                                        "type": "string",
                                        "format": "password",
                                        "example": "rahasia_baru123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Kata sandi berhasil diatur ulang",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Kata sandi berhasil diatur ulang"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Kesalahan validasi data"
                    }
                }
            }
        }
    },
